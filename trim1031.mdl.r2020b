		  BlockType		  SubSystem
		  Name			  "Compare\nTo Zero"
		  SID			  "40"
		  Ports			  [1, 1]
		  Position		  [270, 330, 300, 360]
		  ZOrder		  -2
		  Object {
		    $PropName		    "MaskObject"
		    $ObjectID		    53
		    $ClassName		    "Simulink.Mask"
		    Type		    "Compare To Zero"
		    Description		    "Simulink:masks:CompareToZero_MD"
		    Initialization	    "blkName = gcb;\n\nif strcmp(get_param(gcbh,'OutDataTypeStr'),'boolean')\n	setValue = 'boolea"
		    "n';\nelse\n    setValue = 'fixdt(0, 8)';\nend\n\nset_param([blkName,'/Compare'],'relop',relop, ...\n	'OutDataTyp"
		    "eStr', setValue, 'ZeroCross', ZeroCross);"
		    SelfModifiable	    "on"
		    Display		    "disp([relop,' 0'])"
		    RunInitForIconRedraw    "on"
		    IconUnits		    "normalized"
		    Capabilities	    "slmaskedcaps(gcbh)"
		    Array {
		    Type		    "Simulink.MaskParameter"
		    Dimension		    3
		    Object {
		    $ObjectID		    54
		    Type		    "popup"
		    Array {
		    Type		    "Cell"
		    Dimension		    6
		    Cell		    "=="
		    Cell		    "~="
		    Cell		    "<"
		    Cell		    "<="
		    Cell		    ">="
		    Cell		    ">"
		    PropName		    "TypeOptions"
